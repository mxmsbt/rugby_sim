# When updating this file don't forget to update MANIFEST.in

# Python related files
build/
*.egg-info/
__pycache__
dist/
# virtual environment
football-env*/

# CMake related directories and files
third_party/gfootball_engine/build*
third_party/gfootball_engine/CMakeFiles/
third_party/gfootball_engine/Testing/
third_party/gfootball_engine/.cmake/
cmake-build-*/
vcpkg_installed/
C[M,m]akeCache.txt
Makefile
cmake_install.cmake
*.a
*.so
*.dylib
*.pyd
*.cbp

# IDE
.idea
.vs*

# macOS
.DS_Store

# virtualenvs (kept local)
.venv/
venv/
rugby-sim-env/

# Generated artifacts (videos, datasets, dumps) — not source
artifacts/

# Asset backups (originals from the football fork, preserved locally for
# rollback but not needed in repository history)
*.football_backup

# Symlink created by setup.py develop mode
/gfootball_engine

# Fonts copied into the engine data dir at install time
third_party/gfootball_engine/fonts/

# Stray root-level __init__.py (not a package marker)
/__init__.py
